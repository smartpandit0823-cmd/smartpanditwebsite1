NODE_ENV=development

# App
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-strong-32-char-secret
JWT_SECRET=replace-with-a-strong-32-char-secret
JWT_EXPIRES_IN_DAYS=30

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smartpandit

# AWS S3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# Google Auth / Maps
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase Admin
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Delhivery
DELHIVERY_API_TOKEN=your-delhivery-token
DELHIVERY_BASE_URL=https://track.delhivery.com
DELHIVERY_PICKUP_LOCATION=SanatanSetu Warehouse
DELHIVERY_ORIGIN_PINCODE=422001
NEXT_PUBLIC_DELHIVERY_PICKUP=SanatanSetu Warehouse
NEXT_PUBLIC_DELHIVERY_ORIGIN=422001

# MSG91 OTP
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-msg91-template-id
MSG91_OTP_EXPIRE_MIN=5
# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/smartpandit?retryWrites=true&w=majority

# ─── NextAuth ─────────────────────────────────────────
AUTH_SECRET=your-super-secret-key-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── AWS S3 ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=smartpandit-assets

# ─── Razorpay ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard

# ─── Email (Nodemailer / SMTP) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SmartPandit <noreply@smartpandit.com>"

# ─── Twilio SMS (Optional) ────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
