NODE_ENV=development

# App
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-strong-32-char-secret
JWT_SECRET=replace-with-a-strong-32-char-secret
JWT_EXPIRES_IN_DAYS=30

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smartpandit?retryWrites=true&w=majority

# AWS S3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# Google Auth / Maps
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Single public Maps key used by both admin and user map screens
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase Admin
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Delhivery
DELHIVERY_API_TOKEN=your-delhivery-token
DELHIVERY_BASE_URL=https://track.delhivery.com
DELHIVERY_PICKUP_LOCATION=YOUR_PICKUP_LOCATION
DELHIVERY_ORIGIN_PINCODE=YOUR_ORIGIN_PINCODE
NEXT_PUBLIC_DELHIVERY_PICKUP=YOUR_PICKUP_LOCATION
NEXT_PUBLIC_DELHIVERY_ORIGIN=YOUR_ORIGIN_PINCODE

# MSG91 OTP (legacy – not used; OTP now handled by Firebase Phone Auth)
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_TEMPLATE_ID=your-msg91-template-id
# MSG91_OTP_EXPIRE_MIN=5
